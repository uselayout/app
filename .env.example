# Layout — Environment Variables
# Copy this file to .env.local and fill in your values

# ─── Required ─────────────────────────────────────────────
# Anthropic API key for layout.md generation and test panel
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Better Auth secret (generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET=generate-a-secret-here

# PostgreSQL connection string (used by Better Auth)
DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres

# ─── Supabase ─────────────────────────────────────────────
# Supabase project URL and anon key (for project data storage)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Service role key for server-side access (bypasses RLS — NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Encryption key for OAuth tokens at rest (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=generate-a-64-char-hex-key-here

# ─── Optional ─────────────────────────────────────────────
# App URL (defaults to http://localhost:3000)
NEXT_PUBLIC_APP_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000

# Figma personal access token (for Figma extraction)
FIGMA_DEFAULT_TOKEN=figd_your-token-here

# ─── Stripe (required for billing, optional for development) ──
STRIPE_SECRET_KEY=sk_test_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-secret-here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here
STRIPE_PRO_PRICE_ID=price_xxx
STRIPE_TEAM_BASE_PRICE_ID=price_xxx
STRIPE_TEAM_SEAT_PRICE_ID=price_xxx
STRIPE_TOPUP_PRICE_ID=price_xxx

# ─── Discord ─────────────────────────────────────────────
# Discord invite URL (used by /discord redirect)
DISCORD_INVITE_URL=https://discord.gg/your-invite-code

# ─── Cross-environment kit promote (set on STAGING only) ────
# Lets staging admins push approved kits straight to layout.design via the
# admin "Publish to production" action. Leave unset on production itself.
PROD_API_BASE_URL=https://layout.design
PROD_ADMIN_API_KEY=production-admin-bearer-token
PROD_SUPABASE_URL=https://supabase-prod.example
PROD_SUPABASE_SERVICE_ROLE_KEY=production-supabase-service-role-jwt
