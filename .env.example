# Layout — Environment Variables
# Copy this file to .env.local and fill in your values

# ─── Required ─────────────────────────────────────────────
# Anthropic API key for DESIGN.md generation and test panel
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Better Auth secret (generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET=generate-a-secret-here

# PostgreSQL connection string (used by Better Auth)
DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres

# ─── Supabase ─────────────────────────────────────────────
# Supabase project URL and anon key (for project data storage)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Optional ─────────────────────────────────────────────
# App URL (defaults to http://localhost:3000)
NEXT_PUBLIC_APP_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000

# Figma personal access token (for Figma extraction)
FIGMA_DEFAULT_TOKEN=figd_your-token-here

# ─── Stripe (required for billing, optional for development) ──
STRIPE_SECRET_KEY=sk_test_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-secret-here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here
STRIPE_PRO_PRICE_ID=price_xxx
STRIPE_TEAM_BASE_PRICE_ID=price_xxx
STRIPE_TEAM_SEAT_PRICE_ID=price_xxx
STRIPE_TOPUP_PRICE_ID=price_xxx
