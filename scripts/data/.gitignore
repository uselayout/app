# Per-run state files written by import-gallery-batch.ts. Reproducible from
# the input JSON, so no point versioning them.
gallery-batch.state.json

# Active input file is a per-run artefact: copy gallery-batch.seed.json to
# gallery-batch.json locally before running, then tweak as needed. Kept
# out of git so iterations don't churn commits.
gallery-batch.json

# Card images downloaded from Dropbox before each batch run. ~2MB total
# but conceptually per-user-asset state, not source.
card-images/
